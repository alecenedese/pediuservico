<?php
/**
 * CONFIGURAÇÃO DO BANCO DE DADOS
 * 
 * INSTRUÇÕES:
 * 1. Copie este arquivo para config.php
 * 2. Substitua os valores abaixo pelas suas credenciais
 * 3. NUNCA envie config.php para o GitHub!
 */

// Configurações do banco de dados
$host = "localhost";           // Host do banco (geralmente localhost)
$usuario = "SEU_USUARIO";      // Usuário do MySQL
$senha = "SUA_SENHA";          // Senha do MySQL
$banco = "NOME_DO_BANCO";      // Nome do banco de dados

// Criar conexão
$con = mysqli_connect($host, $usuario, $senha, $banco);

// Verificar conexão
if (!$con) {
    die("❌ Erro de conexão: " . mysqli_connect_error());
}

// Definir charset para UTF-8
mysqli_set_charset($con, "utf8mb4");

// Timezone
date_default_timezone_set('America/Sao_Paulo');
?>
